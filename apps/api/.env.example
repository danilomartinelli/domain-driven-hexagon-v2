DB_HOST='localhost'
DB_PORT=5432
DB_USERNAME='user'
DB_PASSWORD='password'
DB_NAME='ddh'
PORT=3000

# Security
CORS_ORIGINS=
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache
CACHE_DRIVER=memory
CACHE_DEFAULT_TTL=300

# Auth (JWT)
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=

# Notifications
NOTIFICATION_DRIVER=console

# GraphQL
GQL_MAX_DEPTH=10
GQL_MAX_COMPLEXITY=1000
GQL_MAX_ALIASES=15
