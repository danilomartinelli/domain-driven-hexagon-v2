{
  "name": "domain-driven-hexagon",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "turbo run format",
    "dev": "turbo run start:dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/api/**/*.{ts,js,mjs}": [
      "pnpm -C apps/api exec eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.{ts,js}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "^2"
  },
  "packageManager": "pnpm@9.15.4",
  "volta": {
    "node": "22.14.0"
  },
  "pnpm": {
    "overrides": {
      "braces@<3.0.3": ">=3.0.3",
      "micromatch@<4.0.8": ">=4.0.8",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "@tootallnate/once@<3.0.1": ">=3.0.1"
    },
    "allowedDeprecatedVersions": {
      "@apollo/server-plugin-landing-page-graphql-playground": "4",
      "@types/minimatch": "6",
      "abab": "2",
      "domexception": "2",
      "glob": "7",
      "inflight": "1",
      "lodash.omit": "4",
      "rimraf": "3",
      "sane": "4",
      "subscriptions-transport-ws": "0",
      "w3c-hr-time": "1",
      "whatwg-encoding": "1"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@nestjs/mapped-types>class-validator": "0.15",
        "@apollo/server-plugin-landing-page-graphql-playground>@apollo/server": "5"
      }
    }
  }
}
